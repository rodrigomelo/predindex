# PredIndex Backend Environment Variables
# Copy this to .env and fill in your values

# App
DEBUG=true

# Server
# PORT=5004

# Database (defaults to absolute path inside backend/data/)
# DATABASE_URL=sqlite:////absolute/path/to/predindex.db

# External APIs (optional — add keys when ready)
# ALPHA_VANTAGE_API_KEY=your_key_here
